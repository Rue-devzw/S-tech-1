{
    "spec_name": "S-Tech Solutions UX/UI + Copy Enforcement Spec",
    "version": "1.0.0",
    "enforcement_level": "hard",
    "failure_policy": "Any deviation invalidates implementation",
    "homepage": {
        "hero": {
            "required": true,
            "headline": {
                "text_exact": "Engineering Intelligent Digital Systems — and Keeping Your Technology Working",
                "tag": "h1",
                "max_time_to_visibility_seconds": 5
            },
            "subheadline": {
                "text_exact": "S-Tech Solutions delivers AI-assisted software, web and app development alongside professional device and computer repair services for businesses and individuals."
            },
            "ctas": {
                "primary": {
                    "label_exact": "Book a Consultation",
                    "route": "/booking",
                    "query": {
                        "service": "development"
                    },
                    "style": "solid"
                },
                "secondary": {
                    "label_exact": "Request a Repair Quote",
                    "route": "/contact",
                    "query": {
                        "service": "repairs"
                    },
                    "style": "outline"
                }
            },
            "design_constraints": {
                "full_width_banner": false,
                "layout": "asymmetrical",
                "stock_illustrations": false,
                "motion": {
                    "allowed": true,
                    "type": [
                        "fade",
                        "vertical-translate"
                    ],
                    "trigger": "initial-load-only"
                }
            }
        },
        "service_divisions": {
            "section_title_exact": "What We Build, Maintain, and Improve",
            "cards_required": 4,
            "cards": [
                {
                    "title_exact": "Software & Digital Systems Engineering",
                    "cta_label": "Explore Software Solutions →",
                    "route": "/services/software-systems"
                },
                {
                    "title_exact": "Digital Branding, Design & Growth",
                    "cta_label": "View Digital Growth Services →",
                    "route": "/services/digital-growth"
                },
                {
                    "title_exact": "Device & Computer Repair Services",
                    "cta_label": "Get Repair Support →",
                    "route": "/services/device-repairs"
                },
                {
                    "title_exact": "Digital Products & Tools",
                    "cta_label": "Browse Products →",
                    "route": "/products"
                }
            ],
            "layout_rules": {
                "equal_height_cards": false,
                "default_icon_sets": false,
                "hover_effects": [
                    "subtle-elevation",
                    "border-color-shift"
                ]
            }
        },
        "why_section": {
            "title_exact": "Why Clients Choose S-Tech Solutions",
            "points_exact": [
                "Engineering-First Thinking",
                "AI-Assisted Development",
                "Dual Expertise",
                "Outcome-Driven Work"
            ],
            "design_rules": {
                "icons": false,
                "reveal": "staggered",
                "accent_color_usage": "keywords-only"
            }
        },
        "featured_portfolio": {
            "required": true,
            "title_exact": "Selected Work",
            "card_requirements": [
                "project_name",
                "problem_statement",
                "category_tag"
            ],
            "cta_label_exact": "View Case Study →"
        }
    },
    "services_pages": {
        "global_structure_required": [
            "overview",
            "who_its_for",
            "problems_solved",
            "process",
            "technologies",
            "cta"
        ],
        "software_services_page": {
            "h1_exact": "Software & Digital Systems Engineering",
            "cta_exact": "Schedule a Software Consultation"
        }
    },
    "portfolio": {
        "filters_required": [
            "All",
            "Web & Apps",
            "Systems & Automation",
            "Design",
            "Repairs"
        ],
        "case_study_structure": [
            "Challenge",
            "Solution",
            "Technologies Used",
            "Outcome"
        ]
    },
    "products": {
        "page_title_exact": "Digital Products",
        "intro_exact": "Tools and utilities designed to improve efficiency and solve focused problems.",
        "card_cta_exact": "View Product"
    },
    "contact": {
        "h1_exact": "Let’s Talk",
        "intro_exact": "Tell us what you need. We’ll respond with clarity and direction.",
        "fields_required": [
            "name",
            "email",
            "service_type",
            "message"
        ],
        "submit_cta_exact": "Send Message"
    },
    "booking": {
        "h1_exact": "Book a Consultation",
        "intro_exact": "Choose a time to discuss your project or technical needs."
    },
    "ux_task_flows": {
        "business_client": [
            "Home",
            "Software Services",
            "Portfolio",
            "Booking",
            "Confirmation"
        ],
        "repair_client": [
            "Home",
            "Repairs",
            "Contact",
            "WhatsApp",
            "Quote"
        ],
        "product_buyer": [
            "Home",
            "Products",
            "Product Page",
            "Contact or Purchase"
        ]
    },
    "global_design_rules": {
        "forbidden": [
            "generic hero layouts",
            "stock illustrations",
            "default component styling",
            "template-based sections"
        ],
        "required_principles": [
            "typography hierarchy over decoration",
            "motion supports clarity",
            "outcome-driven content"
        ]
    },
    "anti_replication_test": {
        "question": "Does the interface still communicate hierarchy and intent if color and typography are stripped?",
        "required_answer": true,
        "failure_action": "redesign"
    },
    "final_quality_gate": {
        "criteria": [
            "clear service routing within 5 seconds",
            "no generic UI patterns",
            "conversion paths are explicit",
            "brand feels intentionally engineered"
        ],
        "approval_required": true
    }
}